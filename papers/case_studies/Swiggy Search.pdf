) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 525px"/><img alt="" class="be gp rf i" width="525" height="321" loading="lazy" role="presentation"/></picture></div></div></figure><figure class="qv qw qx qy qz qp rj rk paragraph-image"><div class="rj rk uu"><picture><source srcSet="https://miro.medium.com/v2/resize:fit:640/format:webp/0*Ct5FyguKhqJFnV7G 640w, https://miro.medium.com/v2/resize:fit:720/format:webp/0*Ct5FyguKhqJFnV7G 720w, https://miro.medium.com/v2/resize:fit:750/format:webp/0*Ct5FyguKhqJFnV7G 750w, https://miro.medium.com/v2/resize:fit:786/format:webp/0*Ct5FyguKhqJFnV7G 786w, https://miro.medium.com/v2/resize:fit:828/format:webp/0*Ct5FyguKhqJFnV7G 828w, https://miro.medium.com/v2/resize:fit:1100/format:webp/0*Ct5FyguKhqJFnV7G 1100w, https://miro.medium.com/v2/resize:fit:1042/format:webp/0*Ct5FyguKhqJFnV7G 1042w" sizes="auto, (min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 521px" type="image/webp"/><source data-testid="og" srcSet="https://miro.medium.com/v2/resize:fit:640/0*Ct5FyguKhqJFnV7G 640w, https://miro.medium.com/v2/resize:fit:720/0*Ct5FyguKhqJFnV7G 720w, https://miro.medium.com/v2/resize:fit:750/0*Ct5FyguKhqJFnV7G 750w, https://miro.medium.com/v2/resize:fit:786/0*Ct5FyguKhqJFnV7G 786w, https://miro.medium.com/v2/resize:fit:828/0*Ct5FyguKhqJFnV7G 828w, https://miro.medium.com/v2/resize:fit:1100/0*Ct5FyguKhqJFnV7G 1100w, https://miro.medium.com/v2/resize:fit:1042/0*Ct5FyguKhqJFnV7G 1042w" sizes="auto, (min-resolution: 4dppx) and (max-width: 700px) 50vw, (-webkit-min-device-pixel-ratio: 4) and (max-width: 700px) 50vw, (min-resolution: 3dppx) and (max-width: 700px) 67vw, (-webkit-min-device-pixel-ratio: 3) and (max-width: 700px) 65vw, (min-resolution: 2.5dppx) and (max-width: 700px) 80vw, (-webkit-min-device-pixel-ratio: 2.5) and (max-width: 700px) 80vw, (min-resolution: 2dppx) and (max-width: 700px) 100vw, (-webkit-min-device-pixel-ratio: 2) and (max-width: 700px) 100vw, 521px"/><img alt="" class="be gp rf i" width="521" height="311" loading="lazy" role="presentation"/></picture></div></figure><h2 id="6cef" class="po pp jd bc pq pr ps pt hb pu pv pw hd px py pz qa qb qc qd qe qf qg qh qi qj bh">Conclusion</h2><p id="549f" class="pw-post-body-paragraph os ot jd ou b ov qk ox oy oz ql pb pc he qm pe pf hh qn ph pi hk qo pk pl pm ie bh">We explored a two stage-fine tuning approach for a pre-trained language model suitable for deployment in our infrastructure and evaluated the results for multiple complex search queries qualitatively and quantitatively. <strong class="ou je">Currently this feature is in the experimental phase and is being tested with a small cohort</strong>.</p><h2 id="6afa" class="po pp jd bc pq pr ps pt hb pu pv pw hd px py pz qa qb qc qd qe qf qg qh qi qj bh">Reference</h2><p id="3a93" class="pw-post-body-paragraph os ot jd ou b ov qk ox oy oz ql pb pc he qm pe pf hh qn ph pi hk qo pk pl pm ie bh">This work was published in the 7th Joint International Conference on Data Science &amp; Management of Data (11th ACM IKDD CODS and 29th COMAD) (CODS COMAD 2024), January 4–7, 2024, Bangalore, India.</p><p id="4d8b" class="pw-post-body-paragraph os ot jd ou b ov ow ox oy oz pa pb pc he pd pe pf hh pg ph pi hk pj pk pl pm ie bh"><a class="ab pn" href="https://doi.org/10.1145/3632410.3632428" rel="noopener ugc nofollow" target="_blank">https://doi.org/10.1145/3632410.3632428</a></p></div></div></div></div></section></div></div></article></div><div class="w cg"><div class="cn be ik il im in"><div class="uv uw w la"><div class="un w"><a class="ux af aj al" href="https://medium.com/tag/language-model?source=post_page-----ecda2acc24e6---------------------------------------" rel="noopener follow"><div class="to fw dc uy ip uz va bc b bd v bh fp">Language Model</div></a></div><div class="un w"><a class="ux af aj al" href="https://medium.com/tag/food-delivery?source=post_page-----ecda2acc24e6---------------------------------------" rel="noopener follow"><div class="to fw dc uy ip uz va bc b bd v bh fp">Food Delivery</div></a></div><div class="un w"><a class="ux af aj al" href="https://medium.com/tag/information-retrieval?source=post_page-----ecda2acc24e6---------------------------------------" rel="noopener follow"><div class="to fw dc uy ip uz va bc b bd v bh fp">Information Retrieval</div></a></div><div class="un w"><a class="ux af aj al" href="https://medium.com/tag/swiggy-data-science?source=post_page-----ecda2acc24e6---------------------------------------" rel="noopener follow"><div class="to fw dc uy ip uz va bc b bd v bh fp">Swiggy Data Science</div></a></div><div class="un w"><a class="ux af aj al" href="https://medium.com/tag/deep-learning?source=post_page-----ecda2acc24e6---------------------------------------" rel="noopener follow"><div class="to fw dc uy ip uz va bc b bd v bh fp">Deep Learning</div></a></div></div></div></div><div class="e"></div><footer class="vb vc vd ve vf w k vg vh i"><div class="e z"><div class="w cg"><div class="cn be ik il im in"><div class="w cu vi"><div class="w k mj"><div class="vj e"><span class="e vk vl vm vn t"><div class="w k mj mk"><div class="pw-multi-vote-icon fw ml mm mn mo"><span data-dd-action-name="Susi presentation tracker clap_footer"><a class="ab ac ae fm ag ah ai aj ak al am an ao ap aq" data-testid="footerClapButton" href="https://medium.com/m/signin?actionUrl=https%3A%2F%2Fmedium.com%2F_%2Fvote%