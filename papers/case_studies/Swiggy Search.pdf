pename":"VariantFlag","name":"enable_reliable_follow_experience_backend","valueType":{"__typename":"VariantFlagBoolean","value":true}},{"__typename":"VariantFlag","name":"rex_enable_increase_fyf_social_activity","valueType":{"__typename":"VariantFlagBoolean","value":true}},{"__typename":"VariantFlag","name":"enable_abandoned_paywall_promotion_email","valueType":{"__typename":"VariantFlagBoolean","value":true}},{"__typename":"VariantFlag","name":"enable_address_book_discoverability_setting","valueType":{"__typename":"VariantFlagBoolean","value":true}},{"__typename":"VariantFlag","name":"enable_apple_webhook","valueType":{"__typename":"VariantFlagBoolean","value":true}},{"__typename":"VariantFlag","name":"enable_eventstats_event_processing","valueType":{"__typename":"VariantFlagBoolean","value":true}}],"collectionByDomainOrSlug({\"domainOrSlug\":\"bytes.swiggy.com\"})":{"__ref":"Collection:9556560f659"},"postResult({\"id\":\"ecda2acc24e6\"})":{"__ref":"Post:ecda2acc24e6"}},"ImageMetadata:1*bc9tmmG-dA7ZZVUH_sq24A.png":{"__typename":"ImageMetadata","id":"1*bc9tmmG-dA7ZZVUH_sq24A.png"},"Collection:9556560f659":{"__typename":"Collection","id":"9556560f659","favicon":{"__ref":"ImageMetadata:1*bc9tmmG-dA7ZZVUH_sq24A.png"},"domain":"bytes.swiggy.com","slug":"swiggy-bytes","googleAnalyticsId":null,"name":"Swiggy Bytes — Tech Blog","avatar":{"__ref":"ImageMetadata:1*sQa3vSQd9V4k-PeVNgGg0Q.png"},"description":"Stories on how technology enables Swiggy to provide unparalleled convenience to consumers","subscriberCount":12382,"latestPostsConnection({\"paging\":{\"limit\":1}})":{"__typename":"PostConnection","posts":[{"__ref":"Post:6ab01cca1c08"}]},"compatV3":{"__ref":"Publication:9556560f659"},"viewerEdge":{"__ref":"CollectionViewerEdge:collectionId:9556560f659-viewerId:lo_6466c06cbe52"},"twitterUsername":"swiggyTech","facebookPageId":null},"ImageMetadata:1*sQa3vSQd9V4k-PeVNgGg0Q.png":{"__typename":"ImageMetadata","id":"1*sQa3vSQd9V4k-PeVNgGg0Q.png"},"User:1b80ff5da777":{"__typename":"User","id":"1b80ff5da777","customDomainState":null,"hasSubdomain":false,"username":"aishwary.yadav999"},"Post:6ab01cca1c08":{"__typename":"Post","id":"6ab01cca1c08","firstPublishedAt":1780054445619,"creator":{"__ref":"User:1b80ff5da777"},"collection":{"__ref":"Collection:9556560f659"},"isSeries":false,"mediumUrl":"https:\u002F\u002Fbytes.swiggy.com\u002Ffrom-rigid-rules-to-empathetic-agents-rebuilding-swiggys-order-cancellation-experience-with-llms-6ab01cca1c08","sequence":null,"uniqueSlug":"from-rigid-rules-to-empathetic-agents-rebuilding-swiggys-order-cancellation-experience-with-llms-6ab01cca1c08"},"Publication:9556560f659":{"__typename":"Publication","id":"9556560f659","theme":{"__typename":"PublicationTheme","accentColor":{"__typename":"ColorValue","rgb":""}}},"LinkedAccounts:3c8a14a762c":{"__typename":"LinkedAccounts","mastodon":null,"id":"3c8a14a762c"},"NewsletterV3:184a34e8f66a":{"__typename":"NewsletterV3","id":"184a34e8f66a","type":"NEWSLETTER_TYPE_AUTHOR","slug":"3c8a14a762c","name":"3c8a14a762c","collection":null,"user":{"__ref":"User:3c8a14a762c"}},"User:3c8a14a762c":{"__typename":"User","id":"3c8a14a762c","name":"Adityakiran","username":"adityakiran1895","newsletterV3":{"__ref":"NewsletterV3:184a34e8f66a"},"linkedAccounts":{"__ref":"LinkedAccounts:3c8a14a762c"},"isSuspended":false,"customDomainState":null,"hasSubdomain":false,"verifications":{"__typename":"VerifiedInfo","isBookAuthor":false},"imageId":"0*KBaiRLX5sM8yvgDs","socialStats":{"__typename":"SocialStats","followerCount":58,"followingCount":14,"collectionFollowingCount":3},"bio":"","allowNotes":true,"membership":{"__ref":"Membership:0a9a25e087cf"},"viewerEdge":{"__ref":"UserViewerEdge:userId:3c8a14a762c-viewerId:lo_6466c06cbe52"},"twitterScreenName":""},"Paragraph:d423b3a300fc_0":{"__typename":"Paragraph","id":"d423b3a300fc_0","name":"fc53","type":"H3","href":null,"layout":null,"metadata":null,"text":"Improving search relevance in hyperlocal food delivery using (small) language models","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_1":{"__typename":"Paragraph","id":"d423b3a300fc_1","name":"d20b","type":"P","href":null,"layout":null,"metadata":null,"text":"Co-authored with Jose Mathew, Srinivas N, Jairaj Sathyanarayana","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":16,"end":28,"href":"https:\u002F\u002Fwww.linkedin.com\u002Fin\u002Fjose-mathew-550aa525\u002F","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":30,"end":40,"href":"https:\u002F\u002Fwww.linkedin.com\u002Fin\u002Fsrinivas-n-54a6b98\u002F","anchorType":"LINK","userId":null,"linkMetadata":null},{"__typename":"Markup","type":"A","start":42,"end":63,"href":"https:\u002F\u002Fwww.linkedin.com\u002Fin\u002Fjairajs\u002F","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_2":{"__typename":"Paragraph","id":"d423b3a300fc_2","name":"3f3e","type":"H3","href":null,"layout":null,"metadata":null,"text":"Introduction","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_3":{"__typename":"Paragraph","id":"d423b3a300fc_3","name":"4dd4","type":"P","href":null,"layout":null,"metadata":null,"text":"The ability to accurately understand and serve customer search queries is critical to Swiggy. This need is amplified in food delivery platforms operating in India due to the wide variety of languages, cuisines and tastes. Our platform alone offers millions of items from hundreds of thousands of restaurants across India. Not only do Indian dish names have a tremendous amount of regional variety, international cuisine served in India is typically customised to the Indian palate. This variety is reflected in search queries where these can be a combination of words including dish names, dish categories, cuisine, preparation style, occasions, dietary preferences, just to name a few.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*_m_0xMvExyrSvPDJGM4kfQ.gif":{"__typename":"ImageMetadata","id":"1*_m_0xMvExyrSvPDJGM4kfQ.gif","originalHeight":640,"originalWidth":344,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:d423b3a300fc_4":{"__typename":"Paragraph","id":"d423b3a300fc_4","name":"1420","type":"IMG","href":null,"layout":"OUTSET_ROW","metadata":{"__ref":"ImageMetadata:1*_m_0xMvExyrSvPDJGM4kfQ.gif"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:1*kWp-4lGnAJ5sZHwP3NFxzg.gif":{"__typename":"ImageMetadata","id":"1*kWp-4lGnAJ5sZHwP3NFxzg.gif","originalHeight":644,"originalWidth":346,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:d423b3a300fc_5":{"__typename":"Paragraph","id":"d423b3a300fc_5","name":"3b0b","type":"IMG","href":null,"layout":"OUTSET_ROW_CONTINUE","metadata":{"__ref":"ImageMetadata:1*kWp-4lGnAJ5sZHwP3NFxzg.gif"},"text":"Examples for broad intent queries","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":33,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_6":{"__typename":"Paragraph","id":"d423b3a300fc_6","name":"abe3","type":"P","href":null,"layout":null,"metadata":null,"text":"In Indian food delivery space, often the queries are an amalgamation of multiple intents related to dish preference, dietary preference, time slot of the day and the customer’s latent mood of food preference at that point of search session within the hyperlocal space. A hyperlocal space is defined as a particular geographical area (usually 5 kilometer radius) around the customer with serviceable restaurants available for food delivery. Given the diversity of dishes across multiple restaurants in the country, language models play a huge role in understanding the relevancy between search query and the corresponding dish names suitable for the query.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*m_R9rx-R7owSCGS2":{"__typename":"ImageMetadata","id":"0*m_R9rx-R7owSCGS2","originalHeight":273,"originalWidth":455,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:d423b3a300fc_7":{"__typename":"Paragraph","id":"d423b3a300fc_7","name":"cf98","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*m_R9rx-R7owSCGS2"},"text":"Examples of complex search queries and expected dish names that are relevant to the corresponding queries.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":0,"end":106,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_8":{"__typename":"Paragraph","id":"d423b3a300fc_8","name":"d60f","type":"P","href":null,"layout":null,"metadata":null,"text":"These queries are indicative of the customer’s behavior towards exploring a wide variety of relevant choices for specific requirements. Generic search queries directly related to a dish name are solved using the string matching algorithms but in this paper we are mainly focusing on complex queries where a direct string match might not fetch relevant items. We started with an open source language model almpnet-base-v2 seeking a balance of quality and latency requirements for our use case. We propose a two-stage fine-tuning approach. Figure 1 shows the high level overview of the system.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_9":{"__typename":"Paragraph","id":"d423b3a300fc_9","name":"fe5a","type":"OLI","href":null,"layout":null,"metadata":null,"text":"Unsupervised Fine-tuning a suitable language model based on historical search queries and ordered dish items. This step is to make the language model aware of the text data related to food delivery search and item names across multiple restaurants of the country .","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_10":{"__typename":"Paragraph","id":"d423b3a300fc_10","name":"f90d","type":"OLI","href":null,"layout":null,"metadata":null,"text":"We further fine-tune the model with query,item pairs of data created manually. Here, we relied on our internal food intelligence knowledge taxonomy that categorizes all the food items, we further curated the possible complex queries for each category and relevant food items for each query. We also performed data augmentation using large language models available and verified further for the data quality. This stage helped the language model to establish the relationship between query keywords and relevant item names.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_11":{"__typename":"Paragraph","id":"d423b3a300fc_11","name":"25ab","type":"OLI","href":null,"layout":null,"metadata":null,"text":"After two stage fine-tuning, this model is used to retrieve the top items among all the serviceable items in a particular area for a given query based on embedding similarity. We specifically focus only on the retrieval part of the search recommendation in this paper.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*4fi1jrYAGLyL6zWu":{"__typename":"ImageMetadata","id":"0*4fi1jrYAGLyL6zWu","originalHeight":505,"originalWidth":656,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:d423b3a300fc_12":{"__typename":"Paragraph","id":"d423b3a300fc_12","name":"dfe2","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*4fi1jrYAGLyL6zWu"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_13":{"__typename":"Paragraph","id":"d423b3a300fc_13","name":"b424","type":"H3","href":null,"layout":null,"metadata":null,"text":"Methodology","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_14":{"__typename":"Paragraph","id":"d423b3a300fc_14","name":"b586","type":"H3","href":null,"layout":null,"metadata":null,"text":"Unsupervised fine-tuning","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_15":{"__typename":"Paragraph","id":"d423b3a300fc_15","name":"7433","type":"P","href":null,"layout":null,"metadata":null,"text":"In this stage, we collect the historical search queries that eventually got converted into successful orders in our application. Here the search query associated with a particular order, name of the item bought by the customer, metadata of the item from our internal food intelligence knowledge taxonomy that includes category, cui- sine and preparation style are together parsed into a text document. Eg: “Customer searching for ‘healthy juice for summer’ bought the item ‘Sugarcane juice with lemon and ginger’ from the restaurant AB Juice center. This item belongs to ‘beverages’ category and ‘fresh juice making’ preparation style”. Another example is “Customer searching for ‘punjabi curries’ bought the item ‘Paneer lababdar’. This item belongs to ‘curry’ category, ‘Punjabi’ prepa- ration style”. Collection of such documents were then processed to fine-tune the pre-trained language model in an unsupervised manner. We then used Transformers and Sequential Denoising AutoEncoder (TSDAE) approach for unsupervised fine-tuning. TSDAE approach introduces noise to input sequences by deleting and swapping the tokens within the sentences. These noise induced sentences are passed into the encoder of transformer architecture. Another decoder then reconstructs the original input from the noisy data created before. This approach is different and superior to Masked Language Modelling (MLM) mentioned. While MLM approach utilizes the full-length word embeddings for every single token, TSDAE uses the entire sentence vector produced by the encoder in attempting the re-construction of noise induced input sentences. We chose the TSDAE approach in stage one. This stage serves as domain specific adaptation and was able to differentiate the food items based on the user search history. Table 2 shows some of the qualitative analysis. We selected a few dish items and found a relevant and irrelevant pair according to historical user queries. The absolute difference in cosine similarity for relevant and irrelevant pairs is much higher in stage one compared to pre-trained models. After stage one training, we can observe that ‘Fried rice’ is more similar to ‘Noodles’ compared to ‘Rice bath’. ‘Dosa’ is more similar to ‘Idli’ compared to ‘Burger’. ‘Roshogolla’ is more similar to ‘Rajbhog’ compared to ‘Gulab jamun’.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*tSm8Gh4dd0iyYXDm":{"__typename":"ImageMetadata","id":"0*tSm8Gh4dd0iyYXDm","originalHeight":208,"originalWidth":659,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:d423b3a300fc_16":{"__typename":"Paragraph","id":"d423b3a300fc_16","name":"609b","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*tSm8Gh4dd0iyYXDm"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_17":{"__typename":"Paragraph","id":"d423b3a300fc_17","name":"1231","type":"H3","href":null,"layout":null,"metadata":null,"text":"Supervised fine-tuning","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_18":{"__typename":"Paragraph","id":"d423b3a300fc_18","name":"ec5b","type":"P","href":null,"layout":null,"metadata":null,"text":"In the previous stage, fine-tuning mainly happened on existing search queries and the dish items historically ordered from the ap- plication. In this stage we further fine-tune the model by collecting complex search queries and the relevant dish items across the food categories. In the previous stage, historical search data does not contain all types of complexities based on dish descriptors, dietary preferences and regional style of preparation styles. We manually curated a set of queries possible for each dish category and then the relevant items suitable for the query are used to create pairs of training data. This data is passed to fine-tune the previous model obtained from stage one in a supervised manner. As the curated data contains input query and relevant item names, we treated this data as (anchor, positive) samples to pass into the Siamese style of training. However, as there are no strict negative samples that can act as (anchor, negative) samples we stick to Multiple Negatives Ranking Loss (MNR loss). This approach considers the available positive sample as strict positive and randomly chosen samples within the data as soft negatives and optimize the loss function to minimize the approximated mean negative log probability of the data. We also designed an incremental training pipeline where evaluation can be done over a period of time, collect the training samples where the search queries are not performing well, manually curate the relevant items and further pass into training.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_19":{"__typename":"Paragraph","id":"d423b3a300fc_19","name":"b116","type":"H3","href":null,"layout":null,"metadata":null,"text":"Training and results","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_20":{"__typename":"Paragraph","id":"d423b3a300fc_20","name":"ba50","type":"P","href":null,"layout":null,"metadata":null,"text":"The dataset considered for stage one fine-tuning consists of 996,000 historical text documents prepared based on historical orders. These documents were passed into the stage one unsupervised training mentioned above. For stage two fine-tuning, from our existing wide food intelligence database and also leveraging the Large Language models we collected the additional metadata including regional cuisine, main ingredient, preparation style and preferred time slots for the consumption of item. This meta data for every food item helped us in creating the diverse set of possible queries expected from the customers for every dish available in catalogue. We further did manual verification and editing if required for each training sample. In this way we curated more than 300,000 Query-Item relevant pairs which act as anchor-positive pairs to further pass into stage two.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_21":{"__typename":"Paragraph","id":"d423b3a300fc_21","name":"1a5c","type":"P","href":null,"layout":null,"metadata":null,"text":"We trained the two stage fine-tuning approach mentioned with multiple baseline semantic search language models available open source in huggingface repository. To start with, we have a latency constraint for real time query embedding generation of up to 100 milliseconds. This can support our existing search infrastructure based on cpu instances and handling the search requests traffic. Thus, we started with the smallest available models having prior bench- mark performance over semantic search and are meeting the latency requirements. We selected two models “all-mpnet-base-v2” , “all-MiniLM-L6-v2” and further fine-tuned them with stage 1 followed by stage 2. We also trained the base models directly with the training data used in stage2 to understand the importance of stage 1. We also compared the results with the classical BM25 relevance algorithm that uses TF-IDF based scores to understand the importance of leveraging language model embeddings.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_22":{"__typename":"Paragraph","id":"d423b3a300fc_22","name":"4922","type":"P","href":null,"layout":null,"metadata":null,"text":"Our test dataset contains 5000+ samples that includes queries related to 5 international cuisines, 15 Indian regional cuisines, 10+ dietary preferences (Eg: healthy, workout, breakfast etc.,) and they also contain the generic natural language typing words like “Show me, Find me, “ I am looking for’’ etc., Each retrieved item for a query is further tagged with ground truth mentioning about relevancy. We used a binary relevance marking that indicates if the retrieved item is relevant or irrelevant. Table 4 and Table 5 represent the MAP(Mean Average Precision), Precision@1 and Precision@5 metrics measured over two different hyperlocal spaces. We can observe that the serviceable items in sparse hyperlocal space are approximately one sixth of the denser hyperlocal space but our fine-tuned model was able to perform well maintaining the relevancy metrics unlike the base model where the results were not consistent. Among the experiments, “all-mpnet-base-v2” fine-tuned in two stages outperformed all the other variants in overall MAP and Precision@5. We also trained the models directly with stage 2 training data and observed that Precision@1 was significantly improving however overall MAP was still lower. This could be mainly because stage 1 provides the domain adaptation of language model and similar items with different vocabulary come into closer space and hence the retrieved list is superior when the model is trained in two stages. We also observed the results qualitatively. Table 3 represents some of the results from all-mpnet-base-v2 across different stages of fine-tuning. Highlighting a few examples, we can see that after the fine-tuning over two stages, items like “whey protein” are top retrieved items for search query involving words like “gym”. Items like “multigrain loaf, keto and sugar free brownies” are top retrieved items for “healthy bakery items”. “Mysore Pak, Chandrahara” which are famous sweets in Karnataka(State in India) are top retrieved items for “Karnataka famous sweets”. We also ingested an offline incremental training pipeline where the complex customer queries and the existing results can be curated and corrected over a period of time. This is further passed into the stage two fine-tuning for continuous improvement.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*wkZ_tAtcizlwPcnQ":{"__typename":"ImageMetadata","id":"0*wkZ_tAtcizlwPcnQ","originalHeight":274,"originalWidth":1022,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:d423b3a300fc_23":{"__typename":"Paragraph","id":"d423b3a300fc_23","name":"a57b","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*wkZ_tAtcizlwPcnQ"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*7AcLWTlYShoxzQmi":{"__typename":"ImageMetadata","id":"0*7AcLWTlYShoxzQmi","originalHeight":320,"originalWidth":525,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:d423b3a300fc_24":{"__typename":"Paragraph","id":"d423b3a300fc_24","name":"fac1","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*7AcLWTlYShoxzQmi"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"ImageMetadata:0*Ct5FyguKhqJFnV7G":{"__typename":"ImageMetadata","id":"0*Ct5FyguKhqJFnV7G","originalHeight":311,"originalWidth":521,"focusPercentX":null,"focusPercentY":null,"alt":null},"Paragraph:d423b3a300fc_25":{"__typename":"Paragraph","id":"d423b3a300fc_25","name":"49f3","type":"IMG","href":null,"layout":"INSET_CENTER","metadata":{"__ref":"ImageMetadata:0*Ct5FyguKhqJFnV7G"},"text":"","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_26":{"__typename":"Paragraph","id":"d423b3a300fc_26","name":"6cef","type":"H3","href":null,"layout":null,"metadata":null,"text":"Conclusion","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_27":{"__typename":"Paragraph","id":"d423b3a300fc_27","name":"549f","type":"P","href":null,"layout":null,"metadata":null,"text":"We explored a two stage-fine tuning approach for a pre-trained language model suitable for deployment in our infrastructure and evaluated the results for multiple complex search queries qualitatively and quantitatively. Currently this feature is in the experimental phase and is being tested with a small cohort.","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"STRONG","start":220,"end":311,"href":null,"anchorType":null,"userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_28":{"__typename":"Paragraph","id":"d423b3a300fc_28","name":"6afa","type":"H3","href":null,"layout":null,"metadata":null,"text":"Reference","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_29":{"__typename":"Paragraph","id":"d423b3a300fc_29","name":"3a93","type":"P","href":null,"layout":null,"metadata":null,"text":"This work was published in the 7th Joint International Conference on Data Science & Management of Data (11th ACM IKDD CODS and 29th COMAD) (CODS COMAD 2024), January 4–7, 2024, Bangalore, India.","hasDropCap":null,"dropCapImage":null,"markups":[],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Paragraph:d423b3a300fc_30":{"__typename":"Paragraph","id":"d423b3a300fc_30","name":"4d8b","type":"P","href":null,"layout":null,"metadata":null,"text":"https:\u002F\u002Fdoi.org\u002F10.1145\u002F3632410.3632428","hasDropCap":null,"dropCapImage":null,"markups":[{"__typename":"Markup","type":"A","start":0,"end":39,"href":"https:\u002F\u002Fdoi.org\u002F10.1145\u002F3632410.3632428","anchorType":"LINK","userId":null,"linkMetadata":null}],"codeBlockMetadata":null,"iframe":null,"mixtapeMetadata":null},"Membership:0a9a25e087cf":{"__typename":"Membership","id":"0a9a25e087cf"},"CollectionViewerEdge:collectionId:9556560f659-viewerId:lo_6466c06cbe52":{"__typename":"CollectionViewerEdge","id":"collectionId:9556560f659-viewerId:lo_6466c06cbe52","isEditor":false,"isMuting":false},"UserViewerEdge:userId:3c8a14a762c-viewerId:lo_6466c06cbe52":{"__typename":"UserViewerEdge","id":"userId:3c8a14a762c-viewerId:lo_6466c06cbe52","isMuting":false},"TagViewerEdge:tagSlug:language-model-viewerId:lo_6466c06cbe52":{"__typename":"TagViewerEdge","id":"tagSlug:language-model-viewerId:lo_6466c06cbe52","isMuting":false,"isFollowing":false},"Tag:language-model":{"__typename":"Tag","viewerEdge":{"__ref":"TagViewerEdge:tagSlug:language-model-viewerId:lo_6466c06cbe52"},"id":"language-model","displayTitle":"Language Model","normalizedTagSlug":"language-model"},"TagViewerEdge:tagSlug:food-delivery-viewerId:lo_6466c06cbe52":{"__typename":"TagViewerEdge","id":"tagSlug:food-delivery-viewerId:lo_6466c06cbe52","isMuting":false,"isFollowing":false},"Tag:food-delivery":{"__typename":"Tag","viewerEdge":{"__ref":"TagViewerEdge:tagSlug:food-delivery-viewerId:lo_6466c06cbe52"},"id":"food-delivery","displayTitle":"Food Delivery","normalizedTagSlug":"food-delivery"},"TagViewerEdge:tagSlug:information-retrieval-viewerId:lo_6466c06cbe52":{"__typename":"TagViewerEdge","id":"tagSlug:information-retrieval-viewerId:lo_6466c06cbe52","isMuting":false,"isFollowing":false},"Tag:information-retrieval":{"__typename":"Tag","viewerEdge":{"__ref":"TagViewerEdge:tagSlug:information-retrieval-viewerId:lo_6466c06cbe52"},"id":"information-retrieval","displayTitle":"Information Retrieval","normalizedTagSlug":"information-retrieval"},"TagViewerEdge:tagSlug:swiggy-data-science-viewerId:lo_6466c06cbe52":{"__typename":"TagViewerEdge","id":"tagSlug:swiggy-data-science-viewerId:lo_6466c06cbe52","isMuting":false,"isFollowing":false},"Tag:swiggy-data-science":{"__typename":"Tag","viewerEdge":{"__ref":"TagViewerEdge:tagSlug:swiggy-data-science-viewerId:lo_6466c06cbe52"},"id":"swiggy-data-science","displayTitle":"Swiggy Data Science","normalizedTagSlug":"swiggy-data-science"},"TagViewerEdge:tagSlug:deep-learning-viewerId:lo_6466c06cbe52":{"__typename":"TagViewerEdge","id":"tagSlug:deep-learning-viewerId:lo_6466c06cbe52","isMuting":false,"isFollowing":false},"Tag:deep-learning":{"__typename":"Tag","viewerEdge":{"__ref":"TagViewerEdge:tagSlug:deep-learning-viewerId:lo_6466c06cbe52"},"id":"deep-learning","displayTitle":"Deep Learning","normalizedTagSlug":"deep-learning"},"PostViewerEdge:postId:ecda2acc24e6-viewerId:lo_6466c06cbe52":{"__typename":"PostViewerEdge","hasReposted":false,"id":"postId:ecda2acc24e6-viewerId:lo_6466c06cbe52","shouldIndexPostForExternalSearch":true},"Post:ecda2acc24e6":{"__typename":"Post","id":"ecda2acc24e6","isPublished":true,"allowResponses":true,"isLimitedState":false,"collection":{"__ref":"Collection:9556560f659"},"content({\"postMeteringOptions\":{\"referrer\":\"\"}})"